{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import"],
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          "fs",
          "path",
          "os",
          "crypto",
          "stream",
          "util",
          "url",
          "events",
          "child_process",
          "worker_threads"
        ],
        "patterns": ["node:*"]
      }
    ],
    "no-restricted-globals": [
      "error",
      "process",
      "Buffer",
      "global",
      "__dirname",
      "__filename"
    ]
  },
  "overrides": [
    {
      "files": ["test/**/*.ts", "scripts/**/*.mjs"],
      "rules": {
        "no-restricted-imports": "off",
        "no-restricted-globals": "off"
      }
    }
  ]
}
