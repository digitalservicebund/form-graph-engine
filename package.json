{
  "name": "form-graph-engine",
  "version": "0.0.9",
  "description": "TypeScript library for compiling and running form flow graphs",
  "sideEffects": false,
  "scripts": {
    "test": "node --experimental-test-coverage --test test/**/*.test.ts",
    "test:watch": "node --test --watch test/**/*.test.ts",
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "build": "tsc -p tsconfig.build.json",
    "check:browser": "pnpm run build && node scripts/check-browser.mjs"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "form",
    "multi-page",
    "zod"
  ],
  "author": "chohner",
  "license": "MIT",
  "packageManager": "pnpm@11.15.1",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^26.4.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22",
    "pnpm": "^11"
  },
  "peerDependencies": {
    "zod": ">=4.3.0 <5"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^6.0.3",
    "zod": "4.4.3",
    "zod-alt": "npm:zod@4.3.0"
  }
}
