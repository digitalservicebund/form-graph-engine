{
  "name": "form-graph-engine",
  "version": "0.0.3",
  "description": "TypeScript library for compiling and running form flow graphs",
  "sideEffects": false,
  "scripts": {
    "test": "node --experimental-test-coverage --test test/**/*.test.ts",
    "test:watch": "node --test --watch test/**/*.test.ts",
    "typecheck": "tsc",
    "typecheck:watch": "tsc --watch",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "build": "tsc -p tsconfig.build.json",
    "check:browser": "pnpm run build && node scripts/check-browser.mjs"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "form",
    "multi-page",
    "zod"
  ],
  "author": "chohner",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^26.4.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22",
    "pnpm": "^11"
  },
  "peerDependencies": {
    "zod": ">=4 <5"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3",
    "zod": "4.0.0"
  }
}
